# Google Maps API keys, read by app.config.ts at prebuild time.
# EXPO_PUBLIC_ vars are auto-loaded from .env by the Expo CLI.
# Copy this file to .env and fill in your keys (.env is gitignored).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=

# Testing only: set to "true" to show "*" before the correct answer. Default off.
EXPO_PUBLIC_SHOW_CORRECT_ANSWER=false
